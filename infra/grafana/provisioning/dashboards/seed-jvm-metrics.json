          "legendFormat": "Catalog — utilisé",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_max_bytes{job=\"catalog-service\", area=\"heap\"})",
          "legendFormat": "Catalog — max",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"lot-service\", area=\"heap\"})",
          "legendFormat": "Lot — utilisé",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_max_bytes{job=\"lot-service\", area=\"heap\"})",
          "legendFormat": "Lot — max",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"stock-service\", area=\"heap\"})",
          "legendFormat": "Stock — utilisé",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"order-service\", area=\"heap\"})",
          "legendFormat": "Order — utilisé",
          "refId": "F"
        }
      ],
