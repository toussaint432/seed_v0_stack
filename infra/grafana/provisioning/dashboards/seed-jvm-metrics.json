          { "matcher": { "id": "byName", "options": "Catalog — utilisé" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Catalog — max" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Lot — utilisé" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Lot — max" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Stock — utilisé" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Order — utilisé" }, "properties": [{ "id": "color", "value": { "fixedColor": "#a855f7", "mode": "fixed" } }] }
