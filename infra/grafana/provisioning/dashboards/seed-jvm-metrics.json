          { "matcher": { "id": "byName", "options": "Stock" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Order" }, "properties": [{ "id": "color", "value": { "fixedColor": "#a855f7", "mode": "fixed" } }] },
