    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Process — Utilisation par microservice (%)",
      "description": "Pourcentage d'utilisation CPU par le processus JVM. Une valeur élevée persistante indique une saturation ou une boucle infinie.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "process_cpu_usage{job=\"catalog-service\"} * 100",
          "legendFormat": "Catalog",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "process_cpu_usage{job=\"lot-service\"} * 100",
          "legendFormat": "Lot",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "process_cpu_usage{job=\"stock-service\"} * 100",
          "legendFormat": "Stock",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "process_cpu_usage{job=\"order-service\"} * 100",
          "legendFormat": "Order",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "system_cpu_usage * 100",
          "legendFormat": "Système (host)",
          "refId": "E"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "% CPU",
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(239,68,68,0.4)", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Catalog" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
