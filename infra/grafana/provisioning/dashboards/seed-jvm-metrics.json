    {
      "id": 2,
      "type": "stat",
      "title": "CPU moyen — Tous services",
      "description": "Utilisation CPU process moyenne agrégée sur les 4 microservices",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "avg(process_cpu_usage{job=~\"catalog-service|lot-service|stock-service|order-service\"}) * 100",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#4f46e5", "value": null },
              { "color": "#7c3aed", "value": 30 },
              { "color": "#f59e0b", "value": 60 },
              { "color": "#ef4444", "value": 80 }
            ]
          },
          "unit": "percent",
          "decimals": 1,
          "noValue": "N/A"
        },
        "overrides": []
