    {
      "id": 2,
      "type": "stat",
      "title": "Keycloak — Statut",
      "description": "Keycloak est-il opérationnel ? (1 = UP, 0 = DOWN)",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "up{job=\"keycloak\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          },
          "noValue": "INCONNU"
        },
        "overrides": []
      }
    },
