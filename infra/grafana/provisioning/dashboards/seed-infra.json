    {
      "id": 10,
      "type": "row",
      "title": "Keycloak IAM — Authentification & Ressources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Keycloak — Connexions réussies vs échouées",
      "description": "Nombre de logins réussis et échecs d'authentification par minute. Un pic d'échecs peut indiquer une attaque par force brute.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(keycloak_logins_total{realm=\"seed-v0\"}[$__rate_interval]) * 60",
          "legendFormat": "Logins réussis — {{client_id}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(keycloak_failed_login_attempts_total{realm=\"seed-v0\"}[$__rate_interval]) * 60",
          "legendFormat": "Échecs — {{error}}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["sum", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "Logins.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Échecs.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 25 }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Keycloak JVM — Heap utilisé",
      "description": "Mémoire Heap de la JVM Keycloak. Surveiller de près : un Heap > 80% est précurseur d'un crash OOM (exit 137).",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"keycloak\", area=\"heap\"})",
          "legendFormat": "Heap utilisé",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_max_bytes{job=\"keycloak\", area=\"heap\"})",
          "legendFormat": "Heap max (limite)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"keycloak\", area=\"nonheap\"})",
          "legendFormat": "Non-Heap (Metaspace)",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(239,68,68,0.15)", "value": 440000000 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Heap utilisé" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] },
          {
            "matcher": { "id": "byName", "options": "Heap max (limite)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          { "matcher": { "id": "byName", "options": "Non-Heap (Metaspace)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#a855f7", "mode": "fixed" } }] }
        ]
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "PostgreSQL — Connexions, Transactions & Performances",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
