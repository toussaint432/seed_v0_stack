    {
      "id": 21,
      "type": "timeseries",
      "title": "PostgreSQL — Connexions actives par base",
      "description": "Nombre de backends (connexions) actifs. PostgreSQL par défaut accepte max 100 connexions. Un pool JDBC mal dimensionné peut saturer rapidement.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "pg_stat_database_numbackends{datname=\"seed\"}",
          "legendFormat": "seed (prod)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "pg_stat_database_numbackends{datname!~\"template.*|postgres\"}",
          "legendFormat": "{{datname}}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(239,68,68,0.4)", "value": 80 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "seed (prod)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "PostgreSQL — Transactions (commit/rollback) par seconde",
      "description": "Débit transactionnel de la base seed. Un rollback élevé indique des erreurs applicatives fréquentes.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{datname=\"seed\"}[$__rate_interval])",
          "legendFormat": "Commits/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"seed\"}[$__rate_interval])",
          "legendFormat": "Rollbacks/s",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Commits/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          {
            "matcher": { "id": "byName", "options": "Rollbacks/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 25 }
            ]
          }
        ]
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "PostgreSQL — Lectures (hits cache vs disque)",
      "description": "Blocs lus depuis le cache partagé (blks_hit) vs disque (blks_read). Un ratio hit/total > 95 % est excellent. Un ratio bas indique que le shared_buffers est trop petit.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(pg_stat_database_blks_hit{datname=\"seed\"}[$__rate_interval])",
          "legendFormat": "Cache hits/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(pg_stat_database_blks_read{datname=\"seed\"}[$__rate_interval])",
          "legendFormat": "Lectures disque/s",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Cache hits/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Lectures disque/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "PostgreSQL — Conflits & Verrous (deadlocks)",
      "description": "Deadlocks = transactions bloquées mutuellement. Même un deadlock occasionnel mérite investigation. Les conflits indiquent une contention sur les ressources.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
          "expr": "rate(pg_stat_database_deadlocks{datname=\"seed\"}[$__rate_interval])",
          "legendFormat": "Deadlocks/s",
          "refId": "A"
        },
