    { "id": 50, "type": "row", "title": "État du Cluster — KPIs Temps Réel", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "panels": [] },

    {
      "id": 2, "type": "stat", "title": "Brokers actifs",
      "description": "Nombre de brokers Kafka opérationnels dans le cluster. Cible : 1 (dev single-node).",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 5 },
      "targets": [{ "expr": "kafka_brokers", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [{ "type": "value", "options": { "0": { "text": "OFFLINE ✕", "color": "red", "index": 0 }, "1": { "text": "1 / 1 ✓", "color": "green", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "noValue": "N/A"
        }, "overrides": []
      }
    },
    {
      "id": 3, "type": "stat", "title": "Consumer Lag total",
      "description": "Lag total toutes partitions et tous consumer groups. Cible : 0. Toute valeur > 0 indique un retard de traitement.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 5 },
      "targets": [{ "expr": "seed:kafka_consumer_lag_total:sum", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "orange", "value": 200 }, { "color": "red", "value": 1000 }] },
          "unit": "short", "noValue": "0"
        }, "overrides": []
      }
    },
    {
      "id": 4, "type": "stat", "title": "Messages produits / min",
      "description": "Débit de messages entrants sur le broker (JMX — OneMinuteRate).",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 5 },
      "targets": [{ "expr": "seed:kafka_messages_in:rate1m", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#eab308", "mode": "fixed" },
          "unit": "short", "decimals": 1, "noValue": "0"
        }, "overrides": []
      }
    },
    {
      "id": 5, "type": "stat", "title": "Topics actifs",
      "description": "Nombre de topics applicatifs (topics internes __ exclus).",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 5 },
      "targets": [{ "expr": "count(count(kafka_topic_partition_current_offset{topic!~\"__.*\"}) by (topic))", "refId": "A", "instant": true }],
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "#eab308", "mode": "fixed" }, "unit": "short", "noValue": "0" }, "overrides": []
      }
    },
    {
      "id": 6, "type": "stat", "title": "Consumer Groups",
      "description": "Nombre de consumer groups actifs consommant des topics.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 5 },
      "targets": [{ "expr": "count(count(kafka_consumergroup_current_offset) by (consumergroup))", "refId": "A", "instant": true }],
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "#f59e0b", "mode": "fixed" }, "unit": "short", "noValue": "0" }, "overrides": []
      }
    },
    {
      "id": 7, "type": "stat", "title": "Partitions sous-répliquées",
      "description": "Nombre de partitions dont les réplicas ne sont pas synchronisés (ISR). Doit être 0 en permanence.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 5 },
      "targets": [{ "expr": "seed:kafka_under_replicated_partitions:count", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [{ "type": "value", "options": { "0": { "text": "0 ✓ OK", "color": "green", "index": 0 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short", "noValue": "N/A"
        }, "overrides": []
      }
    },

    { "id": 51, "type": "row", "title": "Consumer Lag — Analyse détaillée par groupe et topic", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }, "panels": [] },

    {
      "id": 10, "type": "timeseries",
      "title": "Consumer Lag — Par groupe de consommateurs",
      "description": "Évolution du lag par consumer group. Un lag croissant indique que le microservice consommateur ne suit pas le rythme de production. Cible : 0 en permanence.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 11 },
      "targets": [
        { "expr": "seed:kafka_consumer_lag_by_group:sum", "legendFormat": "{{consumergroup}}", "refId": "A" }
      ],
      "options": { "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 25, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "rgba(234,179,8,0.2)", "value": 50 }, { "color": "rgba(239,68,68,0.2)", "value": 500 }] },
          "unit": "short", "min": 0
        }, "overrides": []
      }
    },
    {
      "id": 11, "type": "bargauge",
      "title": "Lag actuel — Classement par groupe",
      "description": "Snapshot du consumer lag actuel. Le groupe avec le lag le plus élevé est en tête.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 11 },
      "targets": [{ "expr": "seed:kafka_consumer_lag_by_group:sum", "legendFormat": "{{consumergroup}}", "refId": "A", "instant": true }],
      "options": { "displayMode": "lcd", "minVizHeight": 10, "minVizWidth": 0, "namePlacement": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true, "valueMode": "color" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "orange", "value": 200 }, { "color": "red", "value": 1000 }] },
          "unit": "short", "min": 0, "noValue": "0"
        }, "overrides": []
      }
    },
    {
      "id": 12, "type": "timeseries",
      "title": "Consumer Lag — Par topic",
      "description": "Lag agrégé par topic. Permet d'identifier quel sujet de messages est en retard (ex : lot-created, transfert-validé, commande-créée).",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "expr": "seed:kafka_consumer_lag_by_topic:sum", "legendFormat": "{{topic}}", "refId": "A" }
      ],
      "options": { "legend": { "calcs": ["max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false },
          "unit": "short", "min": 0
        }, "overrides": []
      }
    },
    {
      "id": 13, "type": "timeseries",
      "title": "Offset courant — Par topic (progression des messages)",
      "description": "Position du dernier message produit par topic. Une courbe plate indique l'absence d'activité. Une pente régulière = activité normale.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 21 },
      "targets": [
        { "expr": "sum(kafka_topic_partition_current_offset{topic!~\"__.*\"}) by (topic)", "legendFormat": "{{topic}}", "refId": "A" }
      ],
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 8, "gradientMode": "none", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "short"
        }, "overrides": []
      }
    },

    { "id": 52, "type": "row", "title": "Throughput Broker — Bytes & Messages (JMX)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }, "panels": [] },

    {
      "id": 20, "type": "timeseries",
      "title": "Bytes entrants / sortants par seconde — Global broker",
      "description": "Débit réseau du broker Kafka (JMX BrokerTopicMetrics). Un pic de bytes-in sans bytes-out correspondant peut indiquer une accumulation non consommée.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 31 },
      "targets": [
        { "expr": "seed:kafka_bytes_in:rate1m", "legendFormat": "Bytes In / s", "refId": "A" },
        { "expr": "seed:kafka_bytes_out:rate1m", "legendFormat": "Bytes Out / s", "refId": "B" },
        { "expr": "rate(kafka_server_brokertopicmetrics_bytesrejectedpersec_onemimuterate{topic!~\"__.*\"}[1m])", "legendFormat": "Bytes Rejetés / s", "refId": "C" }
      ],
      "options": { "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" } },
          "unit": "Bps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Bytes In / s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Bytes Out / s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Bytes Rejetés / s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }, { "id": "custom.fillOpacity", "value": 25 }] }
        ]
      }
    },
    {
      "id": 21, "type": "timeseries",
      "title": "Messages produits / s — Par topic",
      "description": "Taux de production de messages par topic (JMX MessagesInPerSec OneMinuteRate). Reflète l'activité métier de chaque service SEED.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 31 },
      "targets": [
        { "expr": "kafka_server_brokertopicmetrics_messagesinpersec_onemimuterate{topic!~\"__.*\"}", "legendFormat": "{{topic}}", "refId": "A" }
      ],
      "options": { "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 12, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false },
          "unit": "reqps"
        }, "overrides": []
      }
    },

    { "id": 53, "type": "row", "title": "Latence Réseau — Requêtes Produce & Fetch (JMX)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }, "panels": [] },

    {
      "id": 30, "type": "timeseries",
      "title": "Requêtes Produce — Débit & Latence (ms)",
      "description": "Taux de requêtes Produce/s et latence totale (TotalTimeMs p95). Les producteurs sont les microservices SEED publiant des événements.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 41 },
      "targets": [
        { "expr": "kafka_network_requestmetrics_requestspersec_onemimuterate{request=\"Produce\"}", "legendFormat": "Produce req/s", "refId": "A" },
        { "expr": "kafka_network_requestmetrics_totaltimems_95thpercentile{request=\"Produce\"}", "legendFormat": "Produce latence p95 (ms)", "refId": "B" },
        { "expr": "kafka_network_requestmetrics_totaltimems_99thpercentile{request=\"Produce\"}", "legendFormat": "Produce latence p99 (ms)", "refId": "C" }
      ],
      "options": { "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Produce req/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }, { "id": "unit", "value": "reqps" }] },
          { "matcher": { "id": "byName", "options": "Produce latence p95 (ms)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }, { "id": "unit", "value": "ms" }, { "id": "custom.axisPlacement", "value": "right" }] },
          { "matcher": { "id": "byName", "options": "Produce latence p99 (ms)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }, { "id": "unit", "value": "ms" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "custom.lineStyle", "value": { "dash": [6,3], "fill": "dash" } }] }
        ]
      }
    },
    {
      "id": 31, "type": "timeseries",
      "title": "Requêtes Fetch Consumer — Débit & Latence (ms)",
      "description": "Taux de requêtes Fetch/s et latence (TotalTimeMs p95). Les consommateurs sont les microservices SEED lisant les événements.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 41 },
      "targets": [
        { "expr": "kafka_network_requestmetrics_requestspersec_onemimuterate{request=\"FetchConsumer\"}", "legendFormat": "Fetch req/s", "refId": "A" },
        { "expr": "kafka_network_requestmetrics_totaltimems_95thpercentile{request=\"FetchConsumer\"}", "legendFormat": "Fetch latence p95 (ms)", "refId": "B" },
        { "expr": "kafka_network_requestmetrics_requestqueuetimems_95thpercentile{request=\"FetchConsumer\"}", "legendFormat": "Queue time p95 (ms)", "refId": "C" }
      ],
      "options": { "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Fetch req/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }, { "id": "unit", "value": "reqps" }] },
          { "matcher": { "id": "byName", "options": "Fetch latence p95 (ms)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }, { "id": "unit", "value": "ms" }, { "id": "custom.axisPlacement", "value": "right" }] },
          { "matcher": { "id": "byName", "options": "Queue time p95 (ms)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#a855f7", "mode": "fixed" } }, { "id": "unit", "value": "ms" }, { "id": "custom.axisPlacement", "value": "right" } ] }
