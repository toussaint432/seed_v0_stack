        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false }, "unit": "short", "min": 0 },
        "overrides": [
