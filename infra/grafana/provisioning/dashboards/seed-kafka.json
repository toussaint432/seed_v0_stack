        "content": "<div style=\"background:linear-gradient(135deg,#1c1400 0%,#3d2b00 40%,#1a1f00 100%);padding:22px 28px;border-radius:10px;display:flex;align-items:center;justify-content:space-between;border:1px solid rgba(234,179,8,0.25);box-shadow:0 4px 24px rgba(0,0,0,0.4);\"><div style=\"display:flex;align-items:center;gap:18px;\"><div style=\"width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,#d97706,#eab308);display:flex;align-items:center;justify-content:center;font-size:26px;box-shadow:0 4px 12px rgba(234,179,8,0.4);\">📨</div><div><h1 style=\"color:#fefce8;font-size:22px;font-weight:800;margin:0;letter-spacing:-0.03em;font-family:sans-serif;\">Apache Kafka — Supervision Broker & Messaging</h1><p style=\"color:#fcd34d;font-size:13px;margin:5px 0 0;font-family:sans-serif;\">Bus de messages asynchrone SEED · Confluent Kafka 7.6 · ZooKeeper · JMX Exporter · kafka-exporter</p></div></div><div style=\"display:flex;flex-direction:column;align-items:flex-end;gap:8px;\"><div style=\"display:flex;gap:8px;\"><div style=\"background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.35);border-radius:6px;padding:6px 12px;\"><span style=\"color:#fde047;font-size:11px;font-weight:700;font-family:sans-serif;\">📊 Consumer Lag</span></div><div style=\"background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.35);border-radius:6px;padding:6px 12px;\"><span style=\"color:#fde047;font-size:11px;font-weight:700;font-family:sans-serif;\">⚡ Broker JMX</span></div><div style=\"background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.35);border-radius:6px;padding:6px 12px;\"><span style=\"color:#fde047;font-size:11px;font-weight:700;font-family:sans-serif;\">🔄 Réplication</span></div></div><p style=\"color:#a16207;font-size:11px;margin:0;font-family:sans-serif;\">G1GC · Heap 256MB-512MB · 3 partitions par défaut · Rétention 7j/1GB</p></div></div>"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
