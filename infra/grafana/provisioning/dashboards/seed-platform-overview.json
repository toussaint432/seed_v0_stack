    {
      "id": 100, "type": "stat",
      "title": "Score SLO Plateforme",
      "description": "Pourcentage de requêtes réussies (non-5xx) sur les 5 dernières minutes. Cible : > 99%.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 4 },
      "targets": [{ "expr": "seed:slo_http_success:ratio5m * 100", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 95 }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 99.5 }] },
          "unit": "percent", "decimals": 2, "noValue": "N/A"
        }, "overrides": []
      }
    },
    {
      "id": 2, "type": "stat",
      "title": "Services Opérationnels",
      "description": "Microservices Spring Boot actifs (cible 4/4)",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 5, "y": 4 },
      "targets": [{ "expr": "sum(up{component=\"microservice\"})", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [{ "type": "value", "options": { "0": { "text": "0/4", "color": "red", "index": 0 }, "1": { "text": "1/4", "color": "orange", "index": 1 }, "2": { "text": "2/4", "color": "yellow", "index": 2 }, "3": { "text": "3/4", "color": "yellow", "index": 3 }, "4": { "text": "4/4 ✓", "color": "green", "index": 4 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 4 }] },
          "noValue": "0/4"
        }, "overrides": []
      }
    },
