      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "#a855f7", "mode": "fixed" }, "unit": "short", "noValue": "0" }, "overrides": []
      }
    },
    {
      "id": 7, "type": "stat",
      "title": "Consumer Lag Kafka",
      "description": "Lag total tous consumer groups. Cible : 0.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 3, "x": 21, "y": 5 },
      "targets": [{ "expr": "seed:kafka_consumer_lag_total:sum", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 500 }] },
          "unit": "short", "noValue": "0"
        }, "overrides": []
      }
    },

    { "id": 51, "type": "row", "title": "Tendance SLO — Évolution dans le temps", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }, "panels": [] },

    {
      "id": 10, "type": "timeseries",
      "title": "Score SLO Global — Taux de succès HTTP (%)",
      "description": "Évolution du SLO global. Chaque chute en dessous de 99.5% est un incident. La zone rouge représente la violation du SLO.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 12 },
      "targets": [
