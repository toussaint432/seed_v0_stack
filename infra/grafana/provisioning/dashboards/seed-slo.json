    { "id": 53, "type": "row", "title": "Keycloak — Heap OOM Watch", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }, "panels": [] },

    {
      "id": 40, "type": "timeseries",
      "title": "Keycloak JVM Heap — Surveillance OOM (limite 512MB)",
      "description": "Évolution du Heap Keycloak. La zone rouge = danger OOM (exit 137). Maintenir en dessous de 75% (384MB). Redémarrer si > 90%.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 36 },
      "targets": [
        { "expr": "seed:keycloak_heap_usage:ratio * 100", "legendFormat": "Heap utilisé (%)", "refId": "A" },
        { "expr": "sum(jvm_memory_used_bytes{job=\"keycloak\",area=\"heap\"})", "legendFormat": "Heap absolu (bytes)", "refId": "B" }
      ],
      "options": { "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "rgba(251,146,60,0.15)", "value": 75 }, { "color": "rgba(239,68,68,0.25)", "value": 90 }] },
          "unit": "percent", "min": 0, "max": 100
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Heap absolu (bytes)" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "custom.lineStyle", "value": { "dash": [6,3], "fill": "dash" } }, { "id": "custom.lineWidth", "value": 1 }] },
          { "matcher": { "id": "byName", "options": "Heap utilisé (%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f97316", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 41, "type": "gauge",
      "title": "Keycloak Heap — État actuel",
      "description": "Jauge temps réel. Rouge > 90% = OOM imminent → restart requis.",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 9, "w": 5, "x": 14, "y": 36 },
      "targets": [{ "expr": "seed:keycloak_heap_usage:ratio * 100", "refId": "A", "instant": true }],
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "#22c55e", "value": null }, { "color": "#eab308", "value": 60 }, { "color": "#f97316", "value": 75 }, { "color": "#ef4444", "value": 90 }] }, "unit": "percent", "decimals": 1, "noValue": "N/A" }, "overrides": [] }
    },
    {
      "id": 42, "type": "text",
      "title": "Procédure OOM Keycloak",
      "transparent": false,
      "gridPos": { "h": 9, "w": 5, "x": 19, "y": 36 },
