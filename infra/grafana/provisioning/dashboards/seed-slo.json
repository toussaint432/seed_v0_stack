      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "rgba(239,68,68,0.15)", "value": null }, { "color": "transparent", "value": 99.5 }] },
          "unit": "percent", "min": 90, "max": 100.5, "decimals": 3
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Taux de succès (%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Disponibilité services (%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3b82f6", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [6,3], "fill": "dash" } }, { "id": "custom.lineWidth", "value": 1 }] }
        ]
      }
    },

