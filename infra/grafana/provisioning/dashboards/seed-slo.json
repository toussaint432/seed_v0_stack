    { "id": 50, "type": "row", "title": "SLO — Indicateurs Exécutifs", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "panels": [] },

    {
      "id": 2, "type": "stat",
      "title": "SLO — Score global (%)",
      "description": "Pourcentage de requêtes réussies (non-5xx) sur la fenêtre sélectionnée. Objectif : > 99.5 %",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 5 },
      "targets": [{ "expr": "seed:slo_http_success:ratio5m * 100", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "displayName": "Taux de succès",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 95 }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 99.5 }] },
          "unit": "percent", "decimals": 3, "noValue": "N/A",
          "mappings": []
        }, "overrides": []
      }
    },
    {
      "id": 3, "type": "stat",
      "title": "Disponibilité Plateforme",
      "description": "Ratio de services Spring Boot opérationnels",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 6, "y": 5 },
      "targets": [{ "expr": "seed:platform_availability:ratio * 100", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 50 }, { "color": "yellow", "value": 75 }, { "color": "green", "value": 100 }] },
          "unit": "percent", "decimals": 0, "noValue": "N/A"
        }, "overrides": []
      }
    },
    {
      "id": 4, "type": "stat",
      "title": "Latence p95 max",
      "description": "SLO : p95 < 500ms sur tous les services",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 10, "y": 5 },
      "targets": [{ "expr": "max(seed:http_latency_p95:5m) * 1000", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "orange", "value": 500 }, { "color": "red", "value": 1000 }] },
          "unit": "ms", "decimals": 0, "noValue": "N/A"
        }, "overrides": []
      }
    },
    {
      "id": 5, "type": "stat",
      "title": "Taux d'erreurs global",
      "description": "SLO : < 0.5% d'erreurs 5xx",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 14, "y": 5 },
      "targets": [{ "expr": "seed:http_error_rate5xx_total:ratio5m * 100", "refId": "A", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "unit": "percent", "decimals": 3, "noValue": "0 %"
        }, "overrides": []
      }
    },
    {
      "id": 6, "type": "stat",
      "title": "Services surveillés",
      "description": "Nombre total de cibles Prometheus actives (microservices + infra)",
      "datasource": { "type": "prometheus", "uid": "seed-prometheus" },
      "gridPos": { "h": 6, "w": 3, "x": 18, "y": 5 },
